{
  "name": "trainofit",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "wrangler:dev": "wrangler dev worker.ts",
    "wrangler:deploy": "wrangler deploy worker.ts",
    "db:create": "wrangler d1 create trainofit-db",
    "db:migrate": "wrangler d1 execute trainofit-db --remote --file=./drizzle/migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute trainofit-db --local --file=./drizzle/migrations/0001_initial.sql",
    "db:migrate:002": "wrangler d1 execute trainofit-db --remote --file=./drizzle/migrations/0002_add_class_types_and_students.sql",
    "db:migrate:002:local": "wrangler d1 execute trainofit-db --local --file=./drizzle/migrations/0002_add_class_types_and_students.sql",
    "db:migrate:003": "wrangler d1 execute trainofit-db --remote --file=./drizzle/migrations/0003_add_equipment.sql",
    "db:migrate:003:local": "wrangler d1 execute trainofit-db --local --file=./drizzle/migrations/0003_add_equipment.sql",
    "db:migrate:009": "wrangler d1 execute trainofit-db --remote --file=./drizzle/migrations/0009_add_student_plan_relation.sql",
    "db:migrate:009:local": "wrangler d1 execute trainofit-db --local --file=./drizzle/migrations/0009_add_student_plan_relation.sql",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.19.6",
    "@hono/vite-dev-server": "^0.23.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "^7.9.2",
    "@react-router/serve": "^7.9.2",
    "arctic": "^3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.10.6",
    "hono-react-router-adapter": "^0.6.5",
    "isbot": "^5.1.31",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.9.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251119.0",
    "@react-router/dev": "^7.9.2",
    "@tailwindcss/vite": "^4.1.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "better-sqlite3": "^12.4.1",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.49.0"
  },
